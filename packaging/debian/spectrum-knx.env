# Spectrum KNX configuration (systemd EnvironmentFile).
# Restart after changes: sudo systemctl restart spectrum-knx

# --- Web UI -----------------------------------------------------------------
# Address/port the web interface listens on. Use 127.0.0.1 to restrict to
# localhost (e.g. behind a reverse proxy).
BIND_HOST=0.0.0.0
BIND_PORT=8000

# --- Storage (SQLite) -------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:////var/lib/spectrum-knx/spectrum-knx.db

# ETS project file uploaded through the web UI is stored here.
KNX_PROJECT_PATH=/var/lib/spectrum-knx/knx_project.knxproj

# --- KNX connection ---------------------------------------------------------
# Connection type: automatic | routing | tunneling | tunneling_tcp | tunneling_tcp_secure
KNX_CONNECTION_TYPE=automatic

# For tunneling: IP (and optionally port) of your KNX/IP gateway.
#KNX_GATEWAY_IP=192.168.1.10
#KNX_GATEWAY_PORT=3671

# For routing: multicast settings (defaults shown).
#KNX_MULTICAST_GROUP=224.0.23.12
#KNX_MULTICAST_PORT=3671
#KNX_INDIVIDUAL_ADDRESS=15.15.250
#KNX_LOCAL_IP=

# KNX IP Secure (see DEPLOYMENT.md for the full list of KNX_SECURE_* options).
#KNX_KNXKEYS_FILE=/etc/spectrum-knx/keys.knxkeys
#KNX_KNXKEYS_PASSWORD=

# --- Misc -------------------------------------------------------------------
#LOG_LEVEL=info
