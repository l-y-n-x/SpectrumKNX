# Spectrum KNX configuration. This file is read at startup; restart the app
# after changes. Lines starting with # are comments.

# --- Web UI -----------------------------------------------------------------
# 127.0.0.1 = only this machine can open the UI. Use 0.0.0.0 to allow other
# devices on your network.
BIND_HOST=127.0.0.1
BIND_PORT=8000

# --- Storage ----------------------------------------------------------------
# Default: %LOCALAPPDATA%\SpectrumKNX\spectrum-knx.db (SQLite). Uncomment to
# override (use forward slashes):
#DATABASE_URL=sqlite+aiosqlite:///C:/SpectrumKNX/spectrum-knx.db
#KNX_PROJECT_PATH=C:/SpectrumKNX/knx_project.knxproj

# --- KNX connection ---------------------------------------------------------
# Connection type: automatic | routing | tunneling | tunneling_tcp | tunneling_tcp_secure
KNX_CONNECTION_TYPE=automatic

# For tunneling: IP (and optionally port) of your KNX/IP gateway.
#KNX_GATEWAY_IP=192.168.1.10
#KNX_GATEWAY_PORT=3671

# For routing: multicast settings (defaults shown). Windows Firewall will ask
# for permission on first start — allow access for KNX discovery/routing.
#KNX_MULTICAST_GROUP=224.0.23.12
#KNX_MULTICAST_PORT=3671
#KNX_INDIVIDUAL_ADDRESS=15.15.250
#KNX_LOCAL_IP=

# KNX IP Secure (see DEPLOYMENT.md in the repository for all KNX_SECURE_* options).
#KNX_KNXKEYS_FILE=C:/SpectrumKNX/keys.knxkeys
#KNX_KNXKEYS_PASSWORD=

# --- Misc -------------------------------------------------------------------
#LOG_LEVEL=info
